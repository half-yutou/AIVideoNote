# ============================================================
# VideoNote 配置文件模板
# 复制为 .env 后修改:  cp .env.example .env
# ============================================================

# ──── 服务端口 ────

# Go 后端 API 端口
BACKEND_PORT=8080

# Python 转录服务端口
TRANSCRIBER_PORT=9090

# Vue 前端开发服务器端口
FRONTEND_PORT=3015

# ──── 工具路径 ────

# ffmpeg 可执行文件路径
FFMPEG_PATH=ffmpeg

# ffprobe 可执行文件路径
FFPROBE_PATH=ffprobe

# yt-dlp 可执行文件路径
YT_DLP_PATH=yt-dlp

# ──── 转录配置 ────

# 转录超时时间（秒）
TRANSCRIBE_TIMEOUT=600

# 模型大小: tiny / base / small / medium / large-v1 / large-v2 / large-v3 / large-v3-turbo
WHISPER_MODEL=base

# 设备: auto(自动) / cuda(NVIDIA GPU) / cpu
WHISPER_DEVICE=auto

# 推理精度: auto / float16 / int8
WHISPER_COMPUTE=auto

# 束搜索: 1(快,推荐) / 5(慢,略好)
WHISPER_BEAM_SIZE=1

# 转录引擎: fast-whisper / groq / mlx-whisper(macos Mchips)
TRANSCRIBER_TYPE=fast-whisper

# Groq API Key（仅 TRANSCRIBER_TYPE=groq 时需要）
# GROQ_API_KEY=

# ──── 安全 ────

# 数据库加密密钥（64位十六进制字符串，用于加密 API Key）
# 不设置此项时，程序使用内置默认密钥，可直接使用。
# 如需自定义，取消注释并替换为: openssl rand -hex 32
# ENCRYPTION_KEY=

# ──── 存储路径 ────

# 运行时产出目录（音频/转录/笔记）
DATA_DIR=../data

# 上传文件目录
UPLOAD_DIR=../data/uploads

# ──── LLM ────

# LLM 默认 API 地址（前端未配置时的回退）
LLM_DEFAULT_BASE_URL=https://api.openai.com/v1

# ============================================
# VideoNote — 项目通用忽略规则
# Go / Vue / Python / IDE / OS
# ============================================

# -------------------------------------------
# IDE
# -------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# GoLand
*.iml
*.iws
*.ipr

# -------------------------------------------
# OS
# -------------------------------------------
Desktop.ini
$RECYCLE.BIN/

# -------------------------------------------
# Node / Vue
# -------------------------------------------
node_modules/
dist/
.vite/
*.local

# -------------------------------------------
# Go
# -------------------------------------------
*.exe
*.exe~
*.test
*.out
__debug_bin*
go.work.sum

# -------------------------------------------
# Python
# -------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
*.egg

# -------------------------------------------
# 环境变量 & 密钥
# -------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12

# -------------------------------------------
# SQLite
# -------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm

# -------------------------------------------
# 日志 & 临时文件
# -------------------------------------------
log/
*.log
tmp/
temp/
.cache/

# -------------------------------------------
# Docker
# -------------------------------------------
.docker/
docker-compose.override.yml

# -------------------------------------------
# 构建输出
# -------------------------------------------
build/
bin/

# -------------------------------------------
# 运行时生成数据（音频/视频/笔记）
# -------------------------------------------
data/
